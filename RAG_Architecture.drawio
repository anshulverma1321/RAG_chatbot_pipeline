<mxfile host="Electron" modified="2026-06-19T16:00:00.000Z" agent="5.0" version="20.0.0" type="device"><diagram id="diag_rag_ultra_clean" name="RAG Clean Architecture"><mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1150" background="#0F172A" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title_block" value="MULTIMODAL DOCUMENT INTELLIGENCE RAG ARCHITECTURE&#10;Strict Layered Enterprise Middleware Design with Independent QA &amp; Diagnostics Subsystems" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#F8FAFC;align=center;strokeWidth=2;fontSize=14;fontStyle=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="360" y="15" width="880" height="60" as="geometry" /></mxCell><mxCell id="validation_subsystem" value="QA &amp; VALIDATION CO-PROCESS SYSTEM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F1319;strokeColor=#D97706;fontColor=#FBBF24;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="50" y="100" width="280" height="750" as="geometry" /></mxCell><mxCell id="observability_subsystem" value="DIAGNOSTICS &amp; SYSTEM TELEMETRY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F1319;strokeColor=#E11D48;fontColor=#FB7185;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="1270" y="100" width="280" height="750" as="geometry" /></mxCell><mxCell id="l1_presentation" value="L1: PRESENTATION &amp; CLIENT LAYER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#090D16;strokeColor=#0284C7;fontColor=#38BDF8;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="360" y="100" width="880" height="110" as="geometry" /></mxCell><mxCell id="l2_api" value="L2: REST API GATEWAY &amp; ROUTING SERVICE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#090D16;strokeColor=#4F46E5;fontColor=#818CF8;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="360" y="240" width="880" height="110" as="geometry" /></mxCell><mxCell id="l3_cognitive" value="L3: COGNITIVE MIDDLEWARE &amp; ORCHESTRATION PIPELINES" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#090D16;strokeColor=#7C3AED;fontColor=#A78BFA;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="360" y="380" width="880" height="140" as="geometry" /></mxCell><mxCell id="l4_ai" value="L4: MULTIMODAL AI INFERENCE ENGINE &amp; DRIVERS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#090D16;strokeColor=#DB2777;fontColor=#F472B6;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="360" y="550" width="880" height="140" as="geometry" /></mxCell><mxCell id="l5_storage" value="L5: SYSTEM PERSISTENCE &amp; DATA STORAGE FABRIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#090D16;strokeColor=#059669;fontColor=#34D399;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="360" y="720" width="880" height="130" as="geometry" /></mxCell><mxCell id="roadmap" value="FUTURE ARCHITECTURAL ROADMAP &amp; EVOLUTION PATHWAY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F1319;strokeColor=#475569;fontColor=#94A3B8;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingTop=12;spacingLeft=18;strokeWidth=2;arcSize=4;connectable=0;" vertex="1" parent="1"><mxGeometry x="50" y="880" width="1500" height="190" as="geometry" /></mxCell><mxCell id="val_pytest" value="&lt;b&gt;Automated PyTest Suite&lt;/b&gt;&lt;br/&gt;• &lt;i&gt;test_chunking.py&lt;/i&gt; (Partitions)&lt;br/&gt;• &lt;i&gt;test_embeddings.py&lt;/i&gt; (Vectors)&lt;br/&gt;• &lt;i&gt;test_ocr.py&lt;/i&gt; (Paddle/EasyOCR fallback)&lt;br/&gt;• &lt;i&gt;test_whisper.py / test_piper.py&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#18120A;strokeColor=#D97706;fontColor=#FDE68A;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="65" y="155" width="250" height="95" as="geometry" /></mxCell><mxCell id="val_router_apis" value="&lt;b&gt;Validation API Router (validation.py)&lt;/b&gt;&lt;br/&gt;• &lt;i&gt;/image-summary&lt;/i&gt;: Gemini verify&lt;br/&gt;• &lt;i&gt;/ocr&lt;/i&gt;: Baseline extraction checks&lt;br/&gt;• &lt;i&gt;/visual-understanding&lt;/i&gt;: Fusion&lt;br/&gt;• &lt;i&gt;/table-extraction&lt;/i&gt;: pdfplumber&lt;br/&gt;• &lt;i&gt;/pdf-images&lt;/i&gt;: Extract binaries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#18120A;strokeColor=#D97706;fontColor=#FDE68A;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="65" y="270" width="250" height="120" as="geometry" /></mxCell><mxCell id="val_tabular_full" value="&lt;b&gt;Tabular &amp; Full PDF Analysis&lt;/b&gt;&lt;br/&gt;• &lt;i&gt;/tabular-data-analysis&lt;/i&gt;:&lt;br/&gt;  Parses PDFs, XLSX, XLS, CSV to JSON&lt;br/&gt;• &lt;i&gt;/pdf-full-analysis&lt;/i&gt;:&lt;br/&gt;  Parallel pages, tables, images auditor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#18120A;strokeColor=#D97706;fontColor=#FDE68A;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="65" y="410" width="250" height="95" as="geometry" /></mxCell><mxCell id="val_temp_store" value="&lt;b&gt;Validation Temp Cache&lt;/b&gt;&lt;br/&gt;• Path: &lt;i&gt;data/temp/validation_images/&lt;/i&gt;&lt;br/&gt;• Stores transient image extractions&lt;br/&gt;• Exposes `/image/{name}` preview path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#18120A;strokeColor=#D97706;fontColor=#FDE68A;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="65" y="525" width="250" height="80" as="geometry" /></mxCell><mxCell id="val_eval" value="&lt;b&gt;QA Grounding Evaluator&lt;/b&gt;&lt;br/&gt;• Response-Context token alignment&lt;br/&gt;• Hallucination detection validator&lt;br/&gt;• RAG answer exactness verification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#18120A;strokeColor=#D97706;fontColor=#FDE68A;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="65" y="625" width="250" height="85" as="geometry" /></mxCell><mxCell id="val_manual" value="&lt;b&gt;Manual Testing Harness&lt;/b&gt;&lt;br/&gt;• &lt;i&gt;test_manual_validation.py&lt;/i&gt;&lt;br/&gt;• Simulates multi-page client uploads&lt;br/&gt;• Validates raw stream payloads" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#18120A;strokeColor=#D97706;fontColor=#FDE68A;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="65" y="730" width="250" height="85" as="geometry" /></mxCell><mxCell id="obs_diagnostics" value="&lt;b&gt;Startup Check (log_system_check)&lt;/b&gt;&lt;br/&gt;• Python version check &amp; runtime diagnostics&lt;br/&gt;• CUDA / GPU capability active detection&lt;br/&gt;• Connection: Gemini, SQLite, Qdrant DB&lt;br/&gt;• Audio drivers active verification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B080C;strokeColor=#E11D48;fontColor=#FFE4E6;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="1285" y="155" width="250" height="95" as="geometry" /></mxCell><mxCell id="obs_performance" value="&lt;b&gt;Performance Latency Profiler&lt;/b&gt;&lt;br/&gt;• Records end-to-end processing speeds&lt;br/&gt;• Logs text extraction &amp; OCR delay times&lt;br/&gt;• Tracks TTS / STT model conversion time&lt;br/&gt;• Telemetry logging daemon" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B080C;strokeColor=#E11D48;fontColor=#FFE4E6;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="1285" y="270" width="250" height="95" as="geometry" /></mxCell><mxCell id="obs_logger_daemon" value="&lt;b&gt;Structured Logging Daemon (logger.py)&lt;/b&gt;&lt;br/&gt;• &lt;b&gt;app.log&lt;/b&gt;: Core application telemetry&lt;br/&gt;• &lt;b&gt;ingestion.log&lt;/b&gt;: Ingestion page statistics&lt;br/&gt;• &lt;b&gt;retrieval.log&lt;/b&gt;: Vector search &amp; score logs&lt;br/&gt;• &lt;b&gt;chat.log&lt;/b&gt;: Prompt context &amp; LLM outputs&lt;br/&gt;• &lt;b&gt;errors.log&lt;/b&gt;: Structured exception tracebacks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B080C;strokeColor=#E11D48;fontColor=#FFE4E6;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="1285" y="385" width="250" height="200" as="geometry" /></mxCell><mxCell id="obs_alerts" value="&lt;b&gt;System Alerts &amp; Fault Auditing&lt;/b&gt;&lt;br/&gt;• Throttling &amp; API retry controller&lt;br/&gt;• SQLite transaction lock monitor&lt;br/&gt;• Auto-fallback on Gemini timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B080C;strokeColor=#E11D48;fontColor=#FFE4E6;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="1285" y="605" width="250" height="85" as="geometry" /></mxCell><mxCell id="obs_resources" value="&lt;b&gt;Hardware Resource Monitor&lt;/b&gt;&lt;br/&gt;• VRAM usage for Whisper/Piper inference&lt;br/&gt;• RAM thresholds tracking&lt;br/&gt;• Host disk cache utilization metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B080C;strokeColor=#E11D48;fontColor=#FFE4E6;fontSize=10;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.2;" vertex="1" parent="1"><mxGeometry x="1285" y="710" width="250" height="85" as="geometry" /></mxCell><mxCell id="l1_cli_client" value="&lt;b&gt;Interactive CLI Client Shell (cli.py)&lt;/b&gt;&lt;br/&gt;Voice &amp; Text interface, sounddevice audio recorder &amp; wav player" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0A1520;strokeColor=#0284C7;fontColor=#E0F2FE;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="400" y="140" width="360" height="50" as="geometry" /></mxCell><mxCell id="l1_external_client" value="&lt;b&gt;External API / Downstream Client&lt;/b&gt;&lt;br/&gt;Downstream business applications, web interfaces &amp; API consumers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0A1520;strokeColor=#0284C7;fontColor=#E0F2FE;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="820" y="140" width="360" height="50" as="geometry" /></mxCell><mxCell id="l2_fastapi" value="&lt;b&gt;FastAPI Application Instance (app.py)&lt;/b&gt;&lt;br/&gt;CORS gateway, router mappings, payload limits validation (&lt;50MB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B0B20;strokeColor=#4F46E5;fontColor=#EEF2FF;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="400" y="280" width="360" height="50" as="geometry" /></mxCell><mxCell id="l2_uvicorn" value="&lt;b&gt;Uvicorn ASGI Server Instance (server.py)&lt;/b&gt;&lt;br/&gt;Web worker processes, event loops, process binding configuration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B0B20;strokeColor=#4F46E5;fontColor=#EEF2FF;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="820" y="280" width="360" height="50" as="geometry" /></mxCell><mxCell id="l3_ingestion_engine" value="&lt;b&gt;Ingestion Pipeline Engine&lt;br/&gt;(ingestion.py)&lt;/b&gt;&lt;br/&gt;Splits PDF, triggers PaddleOCR / pdfplumber parser, parses table blocks &amp; generates embeddings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#130A2B;strokeColor=#7C3AED;fontColor=#F5F3FF;fontSize=10;align=center;arcSize=8;strokeWidth=2;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="390" y="430" width="240" height="70" as="geometry" /></mxCell><mxCell id="l3_query_engine" value="&lt;b&gt;RAG Query Engine&lt;br/&gt;(query_engine.py)&lt;/b&gt;&lt;br/&gt;Triggers vector search, ranks retrieved contexts, builds LLM prompts &amp; returns grounded response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#130A2B;strokeColor=#7C3AED;fontColor=#F5F3FF;fontSize=10;align=center;arcSize=8;strokeWidth=2;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="680" y="430" width="240" height="70" as="geometry" /></mxCell><mxCell id="l3_audio_orchestrator" value="&lt;b&gt;Audio Subprocess Drivers&lt;br/&gt;(speech_to_text.py, text_to_speech.py)&lt;/b&gt;&lt;br/&gt;Whisper STT file transcriber wrapper &amp; Piper TTS ONNX audio synthesis coordinator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#070716;strokeColor=#7C3AED;fontColor=#F5F3FF;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="970" y="430" width="240" height="70" as="geometry" /></mxCell><mxCell id="l4_gemini_driver" value="&lt;b&gt;Google Gemini API Driver&lt;/b&gt;&lt;br/&gt;• gemini-3.1-flash-lite&lt;br/&gt;• gemini-embedding-2&lt;br/&gt;• Gemini Multimodal Vision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#28081A;strokeColor=#DB2777;fontColor=#FDF2F8;fontSize=10;align=center;arcSize=8;strokeWidth=2;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380" y="590" width="185" height="80" as="geometry" /></mxCell><mxCell id="l4_ocr_engines" value="&lt;b&gt;Local OCR Subsystems&lt;/b&gt;&lt;br/&gt;• PaddleOCR (primary)&lt;br/&gt;• EasyOCR (fallback reader)&lt;br/&gt;• Layout coords merger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D040A;strokeColor=#DB2777;fontColor=#FDF2F8;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="590" y="590" width="185" height="80" as="geometry" /></mxCell><mxCell id="l4_pdf_parsers" value="&lt;b&gt;Native PDF Extractors&lt;/b&gt;&lt;br/&gt;• pdfplumber (table layout)&lt;br/&gt;• pypdf (binary images)&lt;br/&gt;• Text stream parsers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D040A;strokeColor=#DB2777;fontColor=#FDF2F8;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="800" y="590" width="185" height="80" as="geometry" /></mxCell><mxCell id="l4_local_inference" value="&lt;b&gt;Local Audio Inference&lt;/b&gt;&lt;br/&gt;• Whisper STT Local model&lt;br/&gt;• Piper ONNX TTS Engine&lt;br/&gt;• lessac-medium voice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D040A;strokeColor=#DB2777;fontColor=#FDF2F8;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1010" y="590" width="185" height="80" as="geometry" /></mxCell><mxCell id="l5_sqlite_db" value="&lt;b&gt;SQLite relational DB&lt;br/&gt;(rag_tool.db)&lt;/b&gt;&lt;br/&gt;Document index, page segments metadata, chunk text &amp; table schemas" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#011E11;strokeColor=#059669;fontColor=#ECFDF5;fontSize=10;align=center;fontStyle=1;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="400" y="750" width="220" height="75" as="geometry" /></mxCell><mxCell id="l5_qdrant_db" value="&lt;b&gt;Qdrant Vector DB&lt;br/&gt;(data/qdrant/)&lt;/b&gt;&lt;br/&gt;Local vector collections, search index &amp; semantic embeddings store" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#011E11;strokeColor=#059669;fontColor=#ECFDF5;fontSize=10;align=center;fontStyle=1;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="690" y="750" width="220" height="75" as="geometry" /></mxCell><mxCell id="l5_filesystem_cache" value="&lt;b&gt;Local Cache Directory&lt;br/&gt;(data/temp/)&lt;/b&gt;&lt;br/&gt;Uploaded raw documents, page fragments &amp; cached audio outputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#030A07;strokeColor=#059669;fontColor=#ECFDF5;fontSize=10;align=center;arcSize=8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="980" y="750" width="220" height="75" as="geometry" /></mxCell><mxCell id="road_phase_1" value="&lt;b&gt;PHASE 1: DUAL-DUPLEX VOICE STREAMING&lt;/b&gt;&lt;br/&gt;• Establish WebSockets communication channels.&lt;br/&gt;• Real-time duplex audio loop (STT/TTS streaming).&lt;br/&gt;• User interrupt detection (speech barge-in)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#F1F5F9;fontSize=9.5;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="88" y="935" width="320" height="110" as="geometry" /></mxCell><mxCell id="road_phase_2" value="&lt;b&gt;PHASE 2: HYBRID DENSE-SPARSE SEMANTIC SEARCH&lt;/b&gt;&lt;br/&gt;• Integrate BM25 sparse keyword indices inside SQLite.&lt;br/&gt;• Implement Reciprocal Rank Fusion (RRF) rank merger.&lt;br/&gt;• Combine literal keyword hits with semantic dense vectors." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#F1F5F9;fontSize=9.5;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="456" y="935" width="320" height="110" as="geometry" /></mxCell><mxCell id="road_phase_3" value="&lt;b&gt;PHASE 3: GRAPH RAG CONTEXT REINFORCEMENT&lt;/b&gt;&lt;br/&gt;• Run entity-relation extraction on ingested chunks.&lt;br/&gt;• Construct entity knowledge graph inside SQLite DB.&lt;br/&gt;• Query local subgraphs to enrich context templates." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#F1F5F9;fontSize=9.5;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="824" y="935" width="320" height="110" as="geometry" /></mxCell><mxCell id="road_phase_4" value="&lt;b&gt;PHASE 4: AGENTIC SELF-CORRECTION QA FEEDBACK&lt;/b&gt;&lt;br/&gt;• Deploy lightweight auditing agents on response loops.&lt;br/&gt;• Verify facts against original source document chunks.&lt;br/&gt;• Automatically rebuild answers failing validation threshold." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#F1F5F9;fontSize=9.5;align=left;spacingLeft=12;arcSize=6;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1192" y="935" width="320" height="110" as="geometry" /></mxCell><mxCell id="edge_cli_to_app" value="REST API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#818CF8;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l1_cli_client" target="l2_fastapi"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_web_to_app" value="HTTP Request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#818CF8;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l1_external_client" target="l2_fastapi"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_app_to_ingest" value="Ingest PDF" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#818CF8;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l2_fastapi" target="l3_ingestion_engine"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_app_to_query" value="Query Text" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#818CF8;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l2_fastapi" target="l3_query_engine"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_cli_to_audio" value="Audio Stream" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#38BDF8;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="l1_cli_client" target="l3_audio_orchestrator"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_ingest_to_parsers" value="Parse Layout" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#F472B6;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l3_ingestion_engine" target="l4_pdf_parsers"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_ingest_to_ocr" value="OCR Scan" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#F472B6;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l3_ingestion_engine" target="l4_ocr_engines"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_query_to_gemini" value="LLM Request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#F472B6;strokeWidth=1.5;fillColor=none;endArrow=classic;endFill=1;fontSize=9;fontColor=#0F172A;labelBackgroundColor=#F8FAFC;labelBorderColor=#64748B;fontStyle=1;" edge="1" parent="1" source="l3_query_engine" target="l4_gemini_driver"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="edge_audio_to_loca